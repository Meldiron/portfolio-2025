---
import { Icon } from "astro-icon/components";
import type { SocialLink } from "../types/config";

type Props = SocialLink;

const { title, url, icon, external } = Astro.props;
---

<a
  href={url}
  class="social-link-box relative p-4 rounded-xl bg-white/[0.01] border border-white/[0.05] backdrop-blur-3xl shadow-lg shadow-white/[0.01] flex items-center gap-3 overflow-hidden transition-all duration-300 hover:border-white/[0.15] hover:bg-white/[0.05]"
  target={external ? "_blank" : "_self"}
>
  <div class="social-link-glow absolute inset-0 opacity-0 transition-opacity duration-300 pointer-events-none" />
  <Icon name={icon} width={25} height={25} class="relative z-10 transition-transform duration-300" />
  <div class="flex items-center justify-between w-full relative z-10">
    <p class="transition-colors duration-300">{title}</p>
    <div class="rotate-45 opacity-0 -translate-x-1 transition-all duration-300">
      <Icon name="mdi:arrow-up" width={18} height={18} />
    </div>
  </div>
</a>

<style>
  .social-link-box:hover .social-link-glow {
    opacity: 1;
    background: radial-gradient(
      600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(255, 255, 255, 0.06),
      transparent 40%
    );
  }

  .social-link-box:hover .rotate-45 {
    opacity: 60%;
    transform: rotate(45deg) translateX(0);
  }
</style>

<script>
  function initSocialLinks() {
    document.querySelectorAll(".social-link-box").forEach((box) => {
      box.addEventListener("mousemove", (e) => {
        const el = box as HTMLElement;
        const rect = el.getBoundingClientRect();
        const x = (e as MouseEvent).clientX - rect.left;
        const y = (e as MouseEvent).clientY - rect.top;
        el.style.setProperty("--mouse-x", `${x}px`);
        el.style.setProperty("--mouse-y", `${y}px`);
      });
    });
  }

  initSocialLinks();
  document.addEventListener("astro:page-load", initSocialLinks);
</script>
