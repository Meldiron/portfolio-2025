---
import { Icon } from "astro-icon/components";
import type { SocialLink } from "../types/config";

type Props = SocialLink;

const { title, url, icon, external } = Astro.props;
---

<a
  href={url}
  class="p-4 border border-border bg-surface hover:border-muted flex items-center gap-3 transition-colors"
  target={external ? "_blank" : "_self"}
>
  <Icon name={icon} width={25} height={25} />
  <div class="flex items-center justify-between w-full">
    <p class="text-black">{title}</p>
    <div class="rotate-45 text-muted">
      <Icon name="mdi:arrow-up" />
    </div>
  </div>
</a>
