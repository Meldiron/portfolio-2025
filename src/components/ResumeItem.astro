---
import { Image } from "astro:assets";
import type { ResumeItem } from "../types/config";

type Props = ResumeItem;

const { title, company, date } = Astro.props;
---

<a
  target="_blank"
  href={company.url}
  class="py-3 flex items-center justify-between border-b border-border last:border-b-0"
>
  <div class="flex items-center gap-4">
    <Image
      src={company.image}
      alt={company.name}
      width={40}
      height={40}
      class="w-[40px] h-[40px] object-contain border border-border"
    />
    <div>
      <h3 class="font-medium text-black">{title}</h3>
      <p class="hover-underline text-sm text-muted">{company.name}</p>
    </div>
  </div>
  <p class="text-sm text-muted font-mono">{date}</p>
</a>
