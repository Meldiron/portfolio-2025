---
import githubData from "../data/github.json";

type ContributionDay = {
  color: string;
  contributionCount: number;
  date: string;
  weekday: number;
};

type Week = {
  contributionDays: ContributionDay[];
  firstDay: string;
};

type PR = {
  title: string;
  url: string;
  createdAt: string;
  repo: string;
};

type DayCell = {
  color: string;
  date: string;
  count: number;
};

type MonthData = {
  key: string;
  label: string;
  visiblePRs: number;
  days: DayCell[];
  totalContributions: number;
  prs: PR[];
};

function getColor(count: number): string {
  if (count >= 15) return "#39d353";
  if (count >= 10) return "#26a641";
  if (count >= 5) return "#006d32";
  if (count >= 1) return "#0e4429";
  return "rgba(255, 255, 255, 0.05)";
}

const today = new Date().toISOString().split("T")[0];
const startDate = "2021-08-01";

// Deduplicate weeks
const seenWeeks = new Set<string>();
const dedupedWeeks: Week[] = [];
for (const week of githubData.weeks as Week[]) {
  if (!seenWeeks.has(week.firstDay)) {
    seenWeeks.add(week.firstDay);
    dedupedWeeks.push(week);
  }
}

// Group days into their actual months, splitting weeks at month boundaries
const monthsMap = new Map<string, MonthData>();
const monthKeys: string[] = [];

function getOrCreateMonth(date: Date): MonthData {
  const key = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, "0")}`;
  if (!monthsMap.has(key)) {
    const label = date.toLocaleDateString("en-US", {
      month: "long",
      year: "numeric",
    });
    monthsMap.set(key, {
      key,
      label,
      days: [],
      visiblePRs: 0,
      totalContributions: 0,
      prs: [],
    });
    monthKeys.push(key);
  }
  return monthsMap.get(key)!;
}

for (const week of dedupedWeeks) {
  for (const day of week.contributionDays) {
    if (day.date < startDate || day.date > today) continue;
    const d = new Date(day.date);
    const month = getOrCreateMonth(d);
    month.days.push({ color: getColor(day.contributionCount), date: day.date, count: day.contributionCount });
    month.totalContributions += day.contributionCount;
  }
}

// Group PRs into months
const allPRs = githubData.prs as PR[];
for (const pr of allPRs) {
  const d = new Date(pr.createdAt);
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
  const month = monthsMap.get(key);
  if (month) {
    month.prs.push(pr);
  }
}

// Build final array, reversed (newest first)
// Also reverse dayColors within each month so most recent day is first
const months = monthKeys
  .map((key) => {
    const m = monthsMap.get(key)!;
    m.days = [...m.days].reverse();
    return m;
  })
  .reverse();
const INITIAL_PRS = 4;
const SHORT_MONTH_PRS = 3;
for (const m of months) {
  m.visiblePRs = m.days.length <= 28 ? SHORT_MONTH_PRS : INITIAL_PRS;
}
const totalMonths = months.length;
const totalContributions = months.reduce((sum, m) => sum + m.totalContributions, 0);
const totalPRs = (githubData.prs as PR[]).length;
---

<section class="max-w-2xl mx-auto px-6">
  <h2 class="mb-2 text-2xl text-[white]">Open source journey</h2>
  <p class="mb-8 text-sm opacity-40">I have contributed {totalContributions.toLocaleString("sk-SK")} commits and {totalPRs.toLocaleString("sk-SK")} pull requests to the open source community.</p>

  <div id="timeline-container" class="space-y-1">
    {
      months.map((month, i) => (
        <div class:list={["timeline-month flex gap-4 items-start", i >= 5 && "hidden"]}>


          <div class="flex-shrink-0 grid grid-cols-4 gap-1.5 pt-0.5">
            {month.days.map((day) => (
              <div
                class="timeline-square w-5 h-5 rounded"
                style={`background-color: ${day.color}`}
                data-date={new Date(day.date).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })}
                data-count={day.count}
              />
            ))}
          </div>

          <div class="flex-1 min-w-0" x-data="{ showAllPRs: false }">
            <h3 class="text-white font-medium text-lg">{month.label}</h3>
            <p class="text-xs opacity-50 mt-1 mb-3">
              {month.totalContributions} contributions
              {month.prs.length > 0 &&
                ` · ${month.prs.length} pull request${month.prs.length !== 1 ? "s" : ""}`}
            </p>

            {month.prs.length > 0 && i === 0 && (
              <div class="mt-2">
                <button
                  x-show="!showAllPRs"
                  @click="showAllPRs = true"
                  class="text-xs opacity-40 hover:opacity-70 transition-opacity mb-4 -translate-y-2"
                >
                  Show all {month.prs.length} pull request{month.prs.length !== 1 ? "s" : ""}
                </button>
                <div x-show="showAllPRs" class="space-y-1.5">
                  {month.prs.map((pr) => (
                    <a
                      href={pr.url}
                      target="_blank"
                      class="text-xs flex items-start gap-1 opacity-60 hover:opacity-100 transition-opacity"
                    >
                      <span class="opacity-60 flex-shrink-0 mt-px">
                        {pr.repo.split('/')[1]} #{pr.url.split("/").pop()}
                      </span>
                      <span class="truncate">{pr.title}</span>
                    </a>
                  ))}
                  <button
                    @click="showAllPRs = false"
                    class="text-xs opacity-40 hover:opacity-70 mt-2 transition-opacity"
                  >
                    Show less
                  </button>
                </div>
              </div>
            )}

            {month.prs.length > 0 && i > 0 && (
              <div class="mt-2">
                <div class="space-y-1.5">
                  {month.prs.slice(0, month.visiblePRs).map((pr) => (
                    <a
                      href={pr.url}
                      target="_blank"
                      class="text-xs flex items-start gap-1 opacity-60 hover:opacity-100 transition-opacity"
                    >
                      <span class="opacity-60 flex-shrink-0 mt-px">
                        {pr.repo.split('/')[1]} #{pr.url.split("/").pop()}
                      </span>
                      <span class="truncate">{pr.title}</span>
                    </a>
                  ))}
                </div>

                {month.prs.length > month.visiblePRs && (
                  <div>
                    <div x-show="showAllPRs" class="space-y-1.5 mt-1.5">
                      {month.prs.slice(month.visiblePRs).map((pr) => (
                        <a
                          href={pr.url}
                          target="_blank"
                          class="text-xs flex items-start gap-1 opacity-60 hover:opacity-100 transition-opacity"
                        >
                          <span class="opacity-60 flex-shrink-0 mt-px">
                            {pr.repo.split('/')[1]} #{pr.url.split("/").pop()}
                          </span>
                          <span class="truncate">{pr.title}</span>
                        </a>
                      ))}
                      <button
                        x-show="showAllPRs"
                        @click="showAllPRs = false"
                        class="text-xs opacity-40 hover:opacity-70 mt-2 transition-opacity mb-4"
                      >
                        Show less
                      </button>
                    </div>
                    <button
                      x-show="!showAllPRs"
                      @click="showAllPRs = true"
                      class="text-xs opacity-40 hover:opacity-70 mt-2 transition-opacity mb-4"
                    >
                      Show {month.prs.length - month.visiblePRs} more
                    </button>
                  </div>
                )}
              </div>
            )}
          </div>
        </div>
      ))
    }
  </div>
</section>

<div
  id="timeline-popover"
  class="fixed px-2 py-1 rounded bg-neutral-800 border border-neutral-700 text-xs text-white whitespace-nowrap pointer-events-none z-50 opacity-0"
  style="transition: left 0.15s ease-out, top 0.15s ease-out, opacity 0.15s ease-out;"
>
  <p id="timeline-popover-date" class="opacity-50 text-center"></p>
  <p id="timeline-popover-count" class="font-medium text-center"></p>
</div>

<script>
  // Popover via event delegation (single listener instead of one per square)
  const popover = document.getElementById("timeline-popover")!;
  const popoverDate = document.getElementById("timeline-popover-date")!;
  const popoverCount = document.getElementById("timeline-popover-count")!;
  let isVisible = false;

  const container = document.getElementById("timeline-container")!;
  container.addEventListener("mouseover", (e) => {
    const el = (e.target as HTMLElement).closest(".timeline-square") as HTMLElement | null;
    if (!el) return;

    const date = el.dataset.date!;
    const count = parseInt(el.dataset.count!, 10);
    const rect = el.getBoundingClientRect();

    popoverDate.textContent = date;
    popoverCount.textContent = `${count} contribution${count !== 1 ? "s" : ""}`;

    // Measure popover size (ensure it's in the DOM flow for measurement)
    popover.style.visibility = "hidden";
    popover.style.opacity = "0";
    popover.style.display = "block";
    const popoverHeight = popover.offsetHeight;
    const popoverWidth = popover.offsetWidth;
    popover.style.visibility = "";

    const left = rect.left + rect.width / 2 - popoverWidth / 2;
    const top = rect.top - popoverHeight - 6;

    popover.style.left = `${left}px`;
    popover.style.top = `${top}px`;

    if (!isVisible) {
      popover.style.transition = "none";
      popover.offsetHeight;
      popover.style.transition = "left 0.15s ease-out, top 0.15s ease-out, opacity 0.15s ease-out";
    }

    popover.style.opacity = "1";
    isVisible = true;
  });

  container.addEventListener("mouseout", (e) => {
    const el = (e.target as HTMLElement).closest(".timeline-square");
    if (!el) return;
    const related = (e as MouseEvent).relatedTarget as HTMLElement | null;
    if (related?.closest?.(".timeline-square")) return;
    popover.style.opacity = "0";
    isVisible = false;
  });

  // Progressive loading: reveal 1 more month when scrolling near bottom
  const allMonths = document.querySelectorAll(".timeline-month");
  let revealed = 5;

  function maybeReveal() {
    if (revealed >= allMonths.length) return;
    const docHeight = document.documentElement.scrollHeight;
    const scrollBottom = window.scrollY + window.innerHeight;
    if (scrollBottom >= docHeight - 300) {
      (allMonths[revealed] as HTMLElement).classList.remove("hidden");
      revealed++;
      // Check again after reveal in case still near bottom
      requestAnimationFrame(maybeReveal);
    }
  }

  window.addEventListener("scroll", maybeReveal, { passive: true });
  maybeReveal();
</script>
