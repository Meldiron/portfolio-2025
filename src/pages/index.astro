---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { homePageContent, aboutPageContent } from "../config";
import Link from "../components/Link.astro";
import Graph from "../components/Graph.astro";
import SocialLinkBox from "../components/SocialLinkBox.astro";
import ResumeItem from "../components/ResumeItem.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import CommunityStampsBoard from "../components/CommunityStampsBoard.astro";
import AIButtonPill from "../components/AIButtonPill.astro";
import GitHubTimeline from "../components/GitHubTimeline.astro";

const projects = await getCollection("projects");
const totalProjects = projects.length;
projects.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
projects.splice(2);

const posts = await getCollection("posts");
const totalArticles = posts.length;
posts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
posts.splice(2);
for (const post of posts) {
  const { remarkPluginFrontmatter } = await post.render();
  post.data.readingTime = remarkPluginFrontmatter.minutesRead;
}

const tools = [];
for (const category of homePageContent.techstack) {
  for (const tool of category.items) {
    tools.push(tool.name);
  }
}
---

<Layout seo={homePageContent.seo}>
  <section class="mt-14 max-w-2xl mx-auto px-6">
    <div class="flex flex-col min-[520px]:flex-row gap-6 mb-8">
      <Image
        src="/logo.webp"
        alt="Face"
        width={100}
        height={100}
        class="hero-logo-dark rounded-full ring-1 ring-white/15 p-0.5"
      />
      <Image
        src="/logo-light.png"
        alt="Face"
        width={100}
        height={100}
        class="hero-logo-light rounded-full ring-1 ring-white/15 p-0.5 hidden"
      />
      <div class="group flex flex-col justify-center w-fit">
        <h1 class="font-bold text-3xl mb-1">Matej Bačo</h1>
        <p class="text-white/50">
          Engineering lead at <img
            src="https://appwrite.io/assets/logomark/logo.svg"
            alt="Appwrite logo"
            class="inline-block ml-1 mr-0.5 transform translate-y-[-2px] h-4"
          />
          <a
            class="hover-underline hover-underline-appwrite text-white"
            href="https://appwrite.io/"
            target="_blank">Appwrite</a
          >
        </p>
      </div>
    </div>
    <p class="max-w-md mb-4 text-white/60">
      I am impact-driven software engineer from Czech Republic in love with
      everything open source.
    </p>
    <div class="flex flex-wrap gap-4">
      <AIButtonPill />
    </div>
    <p class="mt-3 text-sm">
      <span class="opacity-40 inline-block">Powered by</span>
      <img
        src="/ai-provider.svg"
        class="inline-block ml-1 mr-0.5 transform translate-y-[-2px]"
        width="14"
      />
      <a href="https://universal-prompt.appwrite.network/" target="_blank">
        <span class="inline-block text-white">Universal Prompt</span></a
      >
      <span class="-ml-1 opacity-40 inline-block"
        >, one of my side projects.</span
      >
    </p>
  </section>

  <section class="mx-auto w-full">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="mb-8 text-2xl text-[white]">Open source activity</h2>
    </div>
    <div
      class="relative w-full flex items-center justify-center overflow-hidden"
    >

      </div>
      <Graph />
    </div>
    <div class="mt-4 max-w-2xl mx-auto px-6">
      <Link
        text={`View on GitHub`}
        href={`https://github.com/Meldiron`}
        external={true}
      />
    </div>
  </section>

  <section class="max-w-2xl mx-auto px-6 sm:flex sm:gap-16">
    <h2 class="mb-8 text-lg sm:mb-0 opacity-60 flex-shrink-0 sm:sticky sm:top-6 sm:self-start">Career path</h2>
    <div>
      <div class="mb-6">
        <p>
          Since the day one I worked remotely, which made me disciplined,
          open-minded, and time-flexible individual.
        </p>
      </div>
      <div class="grid grid-cols-1 group">
        {aboutPageContent.work.items.map((item) => <ResumeItem {...item} />)}
      </div>
      <div class="mt-4">
        <Link text="Download my CV" href="/CV_Matej_Baco.pdf" external={true} />
      </div>
    </div>
  </section>

  <section class="max-w-2xl mx-auto px-6">
    <h2 class="mb-8 text-2xl text-[white]">Latest projects</h2>
    <div class="grid grid-cols-1 gap-3 mb-4">
      {
        projects.map((project) => (
          <a
            class="p-4 rounded-xl bg-white/[0.01] border border-white/[0.05] backdrop-blur-3xl shadow-lg shadow-white/[0.01] flex items-center gap-3 hover:bg-white/[0.03] hover:border-white/[0.1] transition-all duration-200"
            href={`/projects/${project.slug}`}
            target="_self"
          >
            <div class="rounded-lg flex-shrink-0 p-2 bg-white/10">
              <img
                src={project.data.image.url}
                alt={project.data.image.alt}
                width={30}
                height={30}
              />
            </div>
            <div class="w-full">
              <p class="text-lg font-medium">{project.data.title}</p>
              <p class="mt-0.5 text-white/50 text-sm">
                {project.data.description}
              </p>
            </div>
            <div class="rotate-45 opacity-40">
              <Icon name="mdi:arrow-up" />
            </div>
          </a>
        ))
      }
    </div>
    <Link
      text={`View all  ${totalProjects} projects`}
      href="/projects"
      external={false}
    />
  </section>

  <section class="max-w-2xl mx-auto px-6">
    <h2 class="mb-8 text-2xl text-[white]">Latest posts</h2>
    <div class="grid grid-cols-1 gap-6 mb-4">
      {
        posts.map((post) => (
          <a
            class="group block -mx-4 px-4 py-3 -my-3 rounded-xl hover:bg-white/[0.03] hover:backdrop-blur-3xl hover:border-white/[0.05] border border-transparent transition-all duration-200"
            href={
              post.data.external ? post.data.external : `/blog/${post.slug}`
            }
            target={post.data.external ? "_blank" : "_self"}
          >
            <div class="flex items-center gap-3 mb-1.5">
              <p class="text-white/30 text-xs font-mono">
                {post.data.pubDate.getDate() +
                  "." +
                  (post.data.pubDate.getMonth() + 1) +
                  "." +
                  post.data.pubDate.getFullYear()}
              </p>
              <div class="h-px flex-1 bg-[var(--glass-border)]"></div>
              <p class="text-xs text-white/30 font-mono">
                {post.data.external ? (
                  <span class="text-white/50">Appwrite</span>
                ) : (
                  <span>{post.data.readingTime}</span>
                )}
              </p>
            </div>
            <h3 class="font-medium text-lg group-hover:text-[var(--text)] transition-colors">{post.data.title}</h3>
            <p class="text-sm text-white/40 mt-1 leading-relaxed">
              {post.data.description}
            </p>
          </a>
        ))
      }
    </div>
    <Link
      text={`View all ${totalArticles} articles`}
      href="/blog"
      external={false}
    />
  </section>

  <section class="max-w-2xl mx-auto px-6">
    <h2 class="mb-8 text-2xl text-[white]">Tech experience</h2>

    <div class="space-y-8">
      {
        homePageContent.techstack.map((item) => (
          <div>
            <h3 class="mb-3 text-lg text-white/50 font-medium">
              {item.name}
            </h3>

            <div class="grid w-full grid-cols-2 xxs:grid-cols-3 xs:grid-cols-4 md:grid-cols-5 gap-2">
              {item.items.map((item) => (
                <button class="group relative col-span-1 overflow-hidden">
                  <div class="relative justify-center p-3 px-3 rounded-xl bg-white/[0.01] border border-white/[0.05] backdrop-blur-3xl shadow-lg shadow-white/[0.01] flex items-center gap-2 overflow-hidden hover:bg-white/[0.03] hover:border-white/[0.1] transition-all duration-200">

                    <div class="flex-strink-0 group-hover:opacity-0 group-hover:ml-[-25px] transition-all duration-500">
                      {item.icon === "__ASTRO__" && (
                        <svg
                          width={20}
                          height={20}
                          xmlns="http://www.w3.org/2000/svg"
                          fill="none"
                          viewBox="0 0 85 107"
                        >
                          <path
                            fill="#fff"
                            d="M27.59 91.136c-4.834-4.418-6.246-13.703-4.232-20.429 3.492 4.241 8.33 5.584 13.342 6.343 7.737 1.17 15.336.732 22.523-2.804.822-.405 1.582-.943 2.48-1.489.675 1.957.85 3.932.615 5.943-.573 4.896-3.01 8.678-6.885 11.545-1.55 1.147-3.19 2.172-4.79 3.253-4.917 3.323-6.247 7.22-4.4 12.888.044.139.084.277.183.614-2.51-1.124-4.344-2.76-5.742-4.911-1.475-2.27-2.177-4.78-2.214-7.498-.019-1.322-.019-2.656-.197-3.96-.434-3.178-1.926-4.601-4.737-4.683-2.884-.084-5.166 1.699-5.771 4.507-.046.216-.113.429-.18.68l.004.001Z"
                          />
                          <path
                            fill="url(#astro_icon_dark-a)"
                            d="M27.59 91.136c-4.834-4.418-6.246-13.703-4.232-20.429 3.492 4.241 8.33 5.584 13.342 6.343 7.737 1.17 15.336.732 22.523-2.804.822-.405 1.582-.943 2.48-1.489.675 1.957.85 3.932.615 5.943-.573 4.896-3.01 8.678-6.885 11.545-1.55 1.147-3.19 2.172-4.79 3.253-4.917 3.323-6.247 7.22-4.4 12.888.044.139.084.277.183.614-2.51-1.124-4.344-2.76-5.742-4.911-1.475-2.27-2.177-4.78-2.214-7.498-.019-1.322-.019-2.656-.197-3.96-.434-3.178-1.926-4.601-4.737-4.683-2.884-.084-5.166 1.699-5.771 4.507-.046.216-.113.429-.18.68l.004.001Z"
                          />
                          <path
                            fill="#fff"
                            d="M0 69.587s14.314-6.973 28.668-6.973L39.49 29.12c.405-1.62 1.588-2.72 2.924-2.72 1.335 0 2.518 1.1 2.924 2.72L56.16 62.614c17 0 28.668 6.973 28.668 6.973S60.514 3.352 60.467 3.219C59.769 1.261 58.591 0 57.003 0H27.827c-1.588 0-2.718 1.261-3.464 3.22C24.311 3.35 0 69.586 0 69.586Z"
                          />
                          <defs>
                            <linearGradient
                              id="astro_icon_dark-a"
                              x1="22.47"
                              x2="69.145"
                              y1="107"
                              y2="84.947"
                              gradientUnits="userSpaceOnUse"
                            >
                              <stop stop-color="#D83333" />
                              <stop offset="1" stop-color="#F041FF" />
                            </linearGradient>
                          </defs>
                        </svg>
                      )}
                      {item.icon !== "__ASTRO__" && (
                        <Icon
                          class={`${item.invert ? "invert" : ""}`}
                          name={item.icon}
                          width={20}
                          height={20}
                        />
                      )}
                    </div>
                    <p class="text-sm line-clamp-1">{item.name}</p>
                  </div>
                </button>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="max-w-2xl mx-auto px-6">
    <h2 class="mb-8 text-2xl text-[white]">Community stamps</h2>
    <div class="mb-4">
      <CommunityStampsBoard />
      <p class="mt-3 text-sm mb-2 text-center">
        <span class="opacity-60 inline-block">Powered by</span>
        <a href="https://appwrite.io/" target="_blank">
          <img
            src="/appwrite.svg"
            class="inline-block ml-1 mr-1 transform translate-y-[-2px]"
            width="12"
          /><span class="inline-block text-[#FD366E]">Appwrite</span></a
        >
        <span class="-ml-1 opacity-60 inline-block"
          >, Cloud platform I worked on.</span
        >
      </p>
    </div>
  </section>

  <section class="max-w-2xl mx-auto px-6 sm:flex sm:gap-16">
    <h2 class="mb-8 text-lg sm:mb-0 opacity-60 flex-shrink-0 sm:sticky sm:top-6 sm:self-start">Let's connect</h2>
    <div>
      <div class="mb-6">
        Reach out to me to collaborate on a fun project, build an integration,
        write an article, or just to say hi.
      </div>
      <div class="grid grid-cols-2 gap-2 group">
        {
          aboutPageContent.connect.links.map((item) => (
            <SocialLinkBox {...item} />
          ))
        }
      </div>
      <div class="mt-6">
        You can also leave me a message and I'll get in touch with you. Let's do
        something amazing together!
      </div>
      <div>
        <form
          class="bg-white/[0.02] mt-4 p-4 rounded-xl border border-white/[0.08] backdrop-blur-3xl flex flex-col gap-3"
          action="https://formbin.almostapps.eu/s/67b1fb59002fe3c932ff"
          method="POST"
          enctype="multipart/form-data"
        >
          <div
            id="contact-success"
            style="display: none;"
            class="bg-green-500/10 rounded-xl p-3 border border-green-500/20"
          >
            <p class="text-green-200 font-semibold text-center">
              Thanks for your message!
            </p>
          </div>

          <div>
            <p class="opacity-60 text-sm mb-2">E-mail address:</p>
            <input
              required
              type="email"
              class="focus:outline-none focus:border-white/20 w-full px-4 py-2.5 bg-white/[0.01] border border-white/[0.05] text-white rounded-xl placeholder-white/30 backdrop-blur-3xl"
              name="sender"
              placeholder="you@example.com"
            />
          </div>

          <div>
            <p class="opacity-60 text-sm mb-2">Message:</p>
            <textarea
              rows="4"
              required
              class="focus:outline-none focus:border-white/20 w-full px-4 py-2.5 bg-white/[0.01] border border-white/[0.05] text-white rounded-xl placeholder-white/30 backdrop-blur-3xl"
              name="message"
              placeholder="Enter your text..."></textarea>
          </div>

          <div class="-mt-1.5">
            <cap-widget
              data-cap-api-endpoint="https://formbin.almostapps.eu/captcha/67b1fb59002fe3c932ff/"
            ></cap-widget>
          </div>

          <button
            type="submit"
            class="bg-white/[0.01] py-2.5 rounded-xl text-white border border-white/[0.05] hover:bg-white/[0.06] hover:border-white/[0.15] backdrop-blur-3xl transition-all duration-200">Send</button
          >
        </form>
        <p class="mt-3 text-sm mb-2 text-center">
          <span class="opacity-60 inline-block">Powered by</span>
          <a href="https://formbin.almostapps.eu/" target="_blank">
            <img
              src="/formbin.svg"
              class="inline-block ml-1 mr-1 transform translate-y-[-2px]"
              width="12"
            /><span class="inline-block text-[#F06225]">FormBin</span></a
          >
          <span class="-ml-1 opacity-60 inline-block"
            >, one of my side projects.</span
          >
        </p>
      </div>
    </div>
  </section>

  <GitHubTimeline />

  <section class="max-w-3xl mx-auto px-6 my-24">
    <p class="text-center opacity-100 italic text-4xl font-semibold leading-relaxed">
      <span class="text-5xl not-italic leading-none opacity-50">&ldquo;</span>Never underestimate the power to make extraordinary things from the smallest of beginnings.<span class="text-5xl not-italic leading-none opacity-50">&rdquo;</span>
    </p>
  </section>
</Layout>

<script>
  let hash = window.location.hash;
  hash = hash.substring(1); // Remove #

  if (hash === "contact-success") {
    const el = document.querySelector("#contact-success") as any;

    el.style.display = "block";
    el.scrollIntoView();
    history.pushState(
      "",
      document.title,
      window.location.pathname + window.location.search,
    );
  }
</script>
