---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { homePageContent, aboutPageContent } from "../config";
import Link from "../components/Link.astro";
import Graph from "../components/Graph.astro";
import SocialLinkBox from "../components/SocialLinkBox.astro";
import ConnectDesignA from "../components/ConnectDesignA.astro";
import CareerDesignA from "../components/CareerDesignA.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import CommunityStampsBoard from "../components/CommunityStampsBoard.astro";
import AIButtonPill from "../components/AIButtonPill.astro";
import GitHubTimeline from "../components/GitHubTimeline.astro";
import PostsDesignC from "../components/PostsDesignC.astro";
import TechDesignA from "../components/TechDesignA.astro";

const projects = await getCollection("projects");
const totalProjects = projects.length;
projects.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
projects.splice(4);

const posts = await getCollection("posts");
const totalArticles = posts.length;
posts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
posts.splice(5);
for (const post of posts) {
  const { remarkPluginFrontmatter } = await post.render();
  post.data.readingTime = remarkPluginFrontmatter.minutesRead;
}

const tools = [];
for (const category of homePageContent.techstack) {
  for (const tool of category.items) {
    tools.push(tool.name);
  }
}
---

<Layout seo={homePageContent.seo}>
  <section class="mt-14 max-w-2xl mx-auto px-6">
    <div class="flex flex-col min-[520px]:flex-row gap-6 mb-8">
      <Image
        src="/logo.webp"
        alt="Face"
        width={100}
        height={100}
        class="hero-logo-dark rounded-full ring-1 ring-white/15 p-0.5"
      />
      <Image
        src="/logo-light.png"
        alt="Face"
        width={100}
        height={100}
        class="hero-logo-light rounded-full ring-1 ring-white/15 p-0.5 hidden"
      />
      <div class="group flex flex-col justify-center w-fit">
        <h1 class="font-bold text-3xl mb-1">Matej Bačo</h1>
        <p class="text-white/50">
          Engineering lead at <img
            src="https://appwrite.io/assets/logomark/logo.svg"
            alt="Appwrite logo"
            class="inline-block ml-1 mr-0.5 transform translate-y-[-2px] h-4"
          />
          <a
            class="hover-underline hover-underline-appwrite text-white"
            href="https://appwrite.io/"
            target="_blank">Appwrite</a
          >
        </p>
      </div>
    </div>
    <p class="max-w-md mb-4 text-white/60">
      I am impact-driven software engineer from Czech Republic in love with
      everything open source.
    </p>
    <div class="flex flex-wrap gap-4">
      <AIButtonPill />
    </div>
    <p class="mt-3 text-sm">
      <span class="opacity-40 inline-block">Powered by</span>
      <img
        src="/ai-provider.svg"
        class="inline-block ml-1 mr-0.5 transform translate-y-[-2px]"
        width="14"
      />
      <a href="https://universal-prompt.appwrite.network/" target="_blank">
        <span class="inline-block text-white">Universal Prompt</span></a
      >
      <span class="-ml-1 opacity-40 inline-block"
        >, one of my side projects.</span
      >
    </p>
  </section>

  <section class="mx-auto w-full">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="mb-8 text-2xl text-[white]">Open source activity</h2>
    </div>
    <div
      class="relative w-full flex items-center justify-center overflow-hidden"
    >

      </div>
      <Graph />
    </div>
    <div class="mt-4 max-w-2xl mx-auto px-6">
      <Link
        text={`View on GitHub`}
        href={`https://github.com/Meldiron`}
        external={true}
      />
    </div>
  </section>

  <section class="max-w-2xl mx-auto px-6">
    <h2 class="mb-2 text-2xl text-[white]">Career path</h2>
    <p class="mb-8 text-white/50 text-sm">Since day one I worked remotely, which made me disciplined, open-minded, and time-flexible.</p>
    <CareerDesignA items={aboutPageContent.work.items} />
    <div class="mt-4">
      <Link text="Download my CV" href="/CV_Matej_Baco.pdf" external={true} />
    </div>
  </section>

  <section class="max-w-2xl mx-auto px-6" x-data="{ current: 0 }">
    <h2 class="mb-8 text-2xl text-[white]">Latest projects</h2>

    <!-- Carousel -->
    <div class="relative mb-4">
      <div id="project-carousel" class="flex gap-4 overflow-x-auto snap-x snap-mandatory pb-4 scroll-smooth project-carousel" style="scroll-padding-left: 0px;">
        {
          projects.map((project) => (
            <a
              href={`/projects/${project.slug}`}
              target="_self"
              class="group flex-shrink-0 w-[240px] sm:w-[300px] snap-start rounded-xl liquid-glass overflow-hidden transition-all duration-200"
            >
              {project.data.cover && (
                <div class="relative h-[160px] overflow-hidden">
                  <img
                    src={project.data.cover.url}
                    alt={project.data.cover.alt}
                    width={320}
                    height={160}
                    class="w-full h-full object-cover object-top transition-transform duration-300 group-hover:scale-105"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent" />
                </div>
              )}
              <div class="p-4">
                <div class="flex items-center gap-2.5 mb-2">
                  <img
                    src={project.data.image.url}
                    alt={project.data.image.alt}
                    width={24}
                    height={24}
                    class="rounded flex-shrink-0"
                  />
                  <h3 class="font-medium">{project.data.title}</h3>
                </div>
                <p class="text-sm text-white/50 line-clamp-2">{project.data.description}</p>
              </div>
            </a>
          ))
        }
        <!-- View all CTA card -->
        <a
          href="/projects"
          class="group flex-shrink-0 w-[240px] sm:w-[300px] snap-start rounded-xl liquid-glass overflow-hidden transition-all duration-200 flex flex-col items-center justify-center gap-3"
        >
          <div class="w-12 h-12 rounded-full bg-white/[0.05] flex items-center justify-center group-hover:bg-white/[0.1] transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 opacity-50">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          </div>
          <p class="text-sm opacity-50 group-hover:opacity-80 transition-opacity">View all {totalProjects} projects</p>
        </a>
      </div>

      <!-- Desktop arrows: left/right of carousel -->
      <button
        id="carousel-prev"
        class="carousel-arrow hidden md:flex absolute -left-14 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-[var(--glass-bg)] border border-[var(--glass-border)] backdrop-blur-xl items-center justify-center hover:bg-[var(--glass-hover)] transition-all z-10"
        aria-label="Previous project"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
        </svg>
      </button>
      <button
        id="carousel-next"
        class="carousel-arrow hidden md:flex absolute -right-14 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-[var(--glass-bg)] border border-[var(--glass-border)] backdrop-blur-xl items-center justify-center hover:bg-[var(--glass-hover)] transition-all z-10"
        aria-label="Next project"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
        </svg>
      </button>
    </div>

    <!-- Mobile arrows: centered below cards -->
    <div class="flex md:hidden justify-center gap-3 mb-4">
      <button
        id="carousel-prev-mobile"
        class="carousel-arrow w-9 h-9 rounded-full bg-[var(--glass-bg)] border border-[var(--glass-border)] backdrop-blur-xl flex items-center justify-center hover:bg-[var(--glass-hover)] transition-all"
        aria-label="Previous project"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
        </svg>
      </button>
      <button
        id="carousel-next-mobile"
        class="carousel-arrow w-9 h-9 rounded-full bg-[var(--glass-bg)] border border-[var(--glass-border)] backdrop-blur-xl flex items-center justify-center hover:bg-[var(--glass-hover)] transition-all"
        aria-label="Next project"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
        </svg>
      </button>
    </div>

    <div class="-mt-3">
        <Link
          text={`View all ${totalProjects} projects`}
          href="/projects"
          external={false}
        />
    </div>
  </section>

  <section class="max-w-2xl mx-auto px-6">
    <h2 class="mb-8 text-2xl text-[white]">Latest posts</h2>
    <PostsDesignC posts={posts} />
    <div class="mt-4">
      <Link text={`View all ${totalArticles} articles`} href="/blog" external={false} />
    </div>
  </section>

  <section class="max-w-2xl mx-auto px-6">
    <h2 class="mb-8 text-2xl text-[white]">Tech experience</h2>
    <TechDesignA techstack={homePageContent.techstack} />
  </section>

  <section class="max-w-2xl mx-auto px-6">
    <h2 class="mb-8 text-2xl text-[white]">Community stamps</h2>
    <div class="mb-4">
      <CommunityStampsBoard />
      <p class="mt-3 text-sm mb-2 text-center">
        <span class="opacity-60 inline-block">Powered by</span>
        <a href="https://appwrite.io/" target="_blank">
          <img
            src="/appwrite.svg"
            class="inline-block ml-1 mr-1 transform translate-y-[-2px]"
            width="12"
          /><span class="inline-block text-[#FD366E]">Appwrite</span></a
        >
        <span class="-ml-1 opacity-60 inline-block"
          >, Cloud platform I worked on.</span
        >
      </p>
    </div>
  </section>

  <section class="max-w-2xl mx-auto px-6">
    <h2 class="mb-8 text-2xl text-[white]">Let's connect</h2>
    <ConnectDesignA links={aboutPageContent.connect.links} />
  </section>

  <GitHubTimeline />

  <section class="max-w-3xl mx-auto px-6 my-24">
    <p class="text-center opacity-100 italic text-4xl font-semibold leading-relaxed">
      <span class="text-5xl not-italic leading-none opacity-50">&ldquo;</span>Never underestimate the power to make extraordinary things from the smallest of beginnings.<span class="text-5xl not-italic leading-none opacity-50">&rdquo;</span>
    </p>
  </section>
</Layout>

<script>
  let hash = window.location.hash;
  hash = hash.substring(1); // Remove #

  if (hash === "contact-success") {
    const el = document.querySelector("#contact-success") as any;

    el.style.display = "block";
    el.scrollIntoView();
    history.pushState(
      "",
      document.title,
      window.location.pathname + window.location.search,
    );
  }

  // Project carousel navigation
  function initCarousel() {
    const carousel = document.getElementById("project-carousel");
    if (!carousel) return;

    const prevBtns = [document.getElementById("carousel-prev"), document.getElementById("carousel-prev-mobile")];
    const nextBtns = [document.getElementById("carousel-next"), document.getElementById("carousel-next-mobile")];

    const cardWidth = carousel.querySelector("a")?.offsetWidth ?? 320;
    const scrollAmount = cardWidth + 16;

    function updateArrows() {
      const atStart = carousel!.scrollLeft <= 5;
      const atEnd = carousel!.scrollLeft + carousel!.clientWidth >= carousel!.scrollWidth - 5;

      for (const btn of prevBtns) {
        if (!btn) continue;
        btn.style.opacity = atStart ? "0.3" : "1";
        btn.style.pointerEvents = atStart ? "none" : "auto";
      }
      for (const btn of nextBtns) {
        if (!btn) continue;
        btn.style.opacity = atEnd ? "0.3" : "1";
        btn.style.pointerEvents = atEnd ? "none" : "auto";
      }
    }

    for (const btn of prevBtns) {
      btn?.addEventListener("click", () => {
        carousel.scrollBy({ left: -scrollAmount, behavior: "smooth" });
      });
    }
    for (const btn of nextBtns) {
      btn?.addEventListener("click", () => {
        carousel.scrollBy({ left: scrollAmount, behavior: "smooth" });
      });
    }

    carousel.addEventListener("scroll", updateArrows, { passive: true });
    updateArrows();
  }

  initCarousel();
  document.addEventListener("astro:page-load", initCarousel);
</script>

<style>
  .project-carousel::-webkit-scrollbar { display: none; }
  .project-carousel { -ms-overflow-style: none; scrollbar-width: none; }
</style>
