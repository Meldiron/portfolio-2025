---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { projectsPageContent } from "../../config";

const projects = await getCollection("projects");
projects.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
---

<Layout seo={projectsPageContent.seo}>
  <section class="mt-10 max-w-2xl mx-auto px-6">
    <p class="section-label mb-4">[ Projects ]</p>
    <h1 class="font-bold text-3xl mb-1 text-black">Projects</h1>
    <p class="text-muted mb-4">Apps and tools made in free time.</p>

    <div class="grid grid-cols-1 gap-4">
      {
        projects.map((project, index) => (
          <div>
            {((projects[index - 1] &&
              new Date(project.data.pubDate).getFullYear() !=
                new Date(projects[index - 1].data.pubDate).getFullYear()) ||
              index === 0) && (
              <div class="flex items-center w-full text-start text-6xl font-light text-black mb-12 mt-6 gap-6">
                <p class="flex-shrink-0 font-mono">
                  {project.data.pubDate.getFullYear()}
                </p>
                <div class="h-px bg-gradient-to-r from-border to-transparent w-full" />
              </div>
            )}
            <div class="p-4 border border-border bg-surface transition-colors">
              <div class="mb-2">
                <a
                  href={"https://github.com/" + project.data.github}
                  target="_blank"
                  class="inline-flex mr-1 flex gap-1 items-center mb-2 w-[fit-content] text-black border-border hover:border-muted border text-sm py-0.5 px-2 font-mono"
                >
                  {" "}
                  <Icon name="mdi:github" size={14} /> {project.data.github}
                </a>

                {project.data.demo && (
                  <a
                    href={"https://" + project.data.demo}
                    target="_blank"
                    class="inline-flex mr-1 flex gap-1 items-center mb-2 w-[fit-content] text-black border-border hover:border-muted border text-sm py-0.5 px-2 font-mono"
                  >
                    {" "}
                    <Icon name="mdi:link-variant" size={14} />{" "}
                    {project.data.demo}
                  </a>
                )}
              </div>

              <a
                class="group"
                href={`/projects/${project.slug}`}
                target="_self"
              >
                <div class="flex items-center gap-3">
                  <div class="flex-shrink-0 p-2 border border-border">
                    <img
                      src={project.data.image.url}
                      alt={project.data.image.alt}
                      width={30}
                      height={30}
                    />
                  </div>
                  <div class="w-full">
                    <div class="flex gap-2">
                      <p class="text-xl text-black group-hover:underline">
                        {project.data.title}
                      </p>
                    </div>
                    <p class="mt-0.5 text-muted text-sm">
                      {project.data.description}
                    </p>
                  </div>
                  <div class="rotate-45 text-muted">
                    <Icon name="mdi:arrow-up" />
                  </div>
                </div>

                {project.data.cover && (
                  <div class="relative">
                    <div class="absolute bottom-0 w-full left-0 h-[100px] bg-gradient-to-b from-transparent to-surface" />
                    <Image
                      src={project.data.cover.url}
                      alt={project.data.cover.alt}
                      width={250}
                      height={150}
                      class="mt-4 w-full h-[150px] object-cover object-top border border-border"
                    />
                  </div>
                )}
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
