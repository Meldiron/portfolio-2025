---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { projectsPageContent } from "../../config";
import YearHeaderC from "../../components/YearHeaderC.astro";

const projects = await getCollection("projects");
projects.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
---

<Layout seo={projectsPageContent.seo}>
  <section class="mt-14 max-w-2xl mx-auto px-6">
    <h1 class="font-bold text-3xl mb-1">Projects</h1>
    <p class="text-white/50 mb-4">Apps and tools made in free time.</p>

    <div class="flex flex-col gap-4">
      {
        projects.map((project, index) => (
          <>
            {((projects[index - 1] &&
              new Date(project.data.pubDate).getFullYear() !=
                new Date(projects[index - 1].data.pubDate).getFullYear()) ||
              index === 0) && (
              <YearHeaderC year={project.data.pubDate.getFullYear()} />
            )}
            <div class="p-4 rounded-xl liquid-glass transition-all duration-200">
              <div class="mb-2">
                <a
                  href={"https://github.com/" + project.data.github}
                  target="_blank"
                  class="inline-flex mr-1 gap-1 items-center mb-2 w-[fit-content] text-white/80 border-white/[0.1] hover:border-white/[0.2] hover:bg-white/[0.05] border rounded-lg text-sm py-0.5 px-2 transition-all"
                >
                  <Icon name="mdi:github" size={14} /> {project.data.github}
                </a>

                {project.data.demo && (
                  <a
                    href={"https://" + project.data.demo}
                    target="_blank"
                    class="inline-flex mr-1 gap-1 items-center mb-2 w-[fit-content] text-white/80 border-white/[0.1] hover:border-white/[0.2] hover:bg-white/[0.05] border rounded-lg text-sm py-0.5 px-2 transition-all"
                  >
                    <Icon name="mdi:link-variant" size={14} />
                    {project.data.demo}
                  </a>
                )}
              </div>

              <a
                class="group"
                href={`/projects/${project.slug}`}
                target="_self"
              >
                <div class="flex items-center gap-3">
                  <div class="rounded-lg flex-shrink-0 p-2 bg-white/[0.08]">
                    <img
                      src={project.data.image.url}
                      alt={project.data.image.alt}
                      width={30}
                      height={30}
                    />
                  </div>
                  <div class="w-full">
                    <p class="text-xl group-hover:text-[var(--text)] transition-colors">
                      {project.data.title}
                    </p>
                    <p class="mt-0.5 text-white/50 text-sm">
                      {project.data.description}
                    </p>
                  </div>
                  <div class="rotate-45 opacity-40">
                    <Icon name="mdi:arrow-up" />
                  </div>
                </div>

                {project.data.cover && (
                  <div class="relative mt-4">
                    <div class="absolute bottom-0 w-full left-0 h-[100px] bg-gradient-to-b from-transparent to-black/90 rounded-b-lg" />
                    <Image
                      src={project.data.cover.url}
                      alt={project.data.cover.alt}
                      width={250}
                      height={150}
                      class="w-full h-[150px] object-cover object-top rounded-lg"
                    />
                  </div>
                )}
              </a>
            </div>
          </>
        ))
      }
    </div>
  </section>
</Layout>
