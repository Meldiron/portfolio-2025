---
import Layout from "../layouts/Layout.astro";
import { aboutPageContent } from "../config";

import { getEntry } from "astro:content";

const entry = await getEntry("pages", "about");
const { Content } = await entry.render();
---

<Layout seo={aboutPageContent.seo}>
  <section class="mt-10 max-w-2xl mx-auto px-6">
    <p class="section-label mb-4">[ About ]</p>
    <h1 class="font-bold text-3xl mb-1 text-black">About me</h1>
    <p class="text-muted mb-10">How I grew into who I am today.</p>

    <article
      class="prose prose-a:text-accent prose-a:underline-offset-4 prose-headings:mb-2 prose-headings:text-black prose-p:text-muted"
    >
      <Content />
    </article>
  </section>
</Layout>
