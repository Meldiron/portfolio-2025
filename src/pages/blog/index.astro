---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { blogPageContent } from "../../config";

const posts = await getCollection("posts");
posts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
for (const post of posts) {
  const { remarkPluginFrontmatter } = await post.render();
  post.data.readingTime = remarkPluginFrontmatter.minutesRead;
}
---

<Layout seo={blogPageContent.seo}>
  <section class="mt-14 max-w-2xl mx-auto px-6">
    <h1 class="font-bold text-3xl mb-1">Blog</h1>
    <p class="text-white/50 mb-14">
      Articles I write in free time, and for employers.
    </p>

    <div class="grid grid-cols-1 gap-4 mb-10">
      {
        posts.map((post, index) => (
          <a
            href={
              post.data.external ? post.data.external : `/blog/${post.slug}`
            }
            target={post.data.external ? "_blank" : "_self"}
            class={`group relative sm:flex sm:flex-row-reverse sm:justify-between sm:gap-6 rounded-xl p-4 liquid-glass transition-all duration-200`}
          >
            <Image
              src={post.data.image.url}
              alt={post.data.image.url}
              width={150}
              height={150}
              class="rounded-lg sm:w-[150px] sm:h-auto sm:aspect-square object-cover w-full h-[150px] border border-white/[0.05] flex-shrink-0"
            />
            <div class="mt-4 sm:my-auto">
              {(post.data.highlight || index === 0) && (
                <p class="mb-2 w-[fit-content] text-white/80 border-white/[0.1] border rounded-lg text-sm py-0.5 px-2">
                  {index === 0 ? "Latest" : "Popular"}
                </p>
              )}
              <p class="text-white/40 mb-2 text-sm font-mono">
                {post.data.pubDate.getDate() +
                  "." +
                  (post.data.pubDate.getMonth() + 1) +
                  "." +
                  post.data.pubDate.getFullYear()}{" "}
                ·{" "}
                <span class="text-white/60">
                  {post.data.external ? "Appwrite" : post.data.readingTime}
                </span>
              </p>
              <h3 class="font-medium text-lg group-hover:text-[var(--text)] transition-colors">{post.data.title}</h3>
              <p class="text-sm text-white/40 mt-2 mb-1 leading-relaxed">
                {post.data.description}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
