---
import { navBarLinks } from "../config";
import type { SEOInfo } from "../types/config";
import { ViewTransitions } from "astro:transitions";

interface Props {
  seo: SEOInfo;
}

const { seo } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/logo.webp" />
    <meta name="generator" content={Astro.generator} />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={seo.image} />
    <ViewTransitions />
    <script is:inline src="https://cdn.jsdelivr.net/npm/appwrite@17.0.0"
    ></script>
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="9cd0e69d-273d-4bbb-88eb-4f10a5019bcd"></script>
  </head>
  <body>
    <!-- Diagonal hatching background -->
    <div class="fixed inset-0 pointer-events-none z-0 bg-hatching"></div>

    <div class="relative z-10">
      <header class="border-b border-border">
        <div
          class="px-6 py-5 max-w-2xl mx-auto flex items-center justify-between"
        >
          <nav>
            <ul class="flex gap-6">
              {
                navBarLinks.map((link) => (
                  <li>
                    <a
                      class="font-mono text-sm uppercase tracking-wider text-muted hover:text-black transition-colors"
                      href={link.url}
                      target={link.external ? "_blank" : "_self"}
                    >
                      {link.title}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>
        </div>
      </header>
      <main class="mb-20 space-y-14">
        <slot />
      </main>
      <footer></footer>
    </div>

    <script is:inline src="/cap.min.js"></script>
  </body>
</html>

<style is:global>
  @import url(https://fonts.bunny.net/css?family=inter:200,200i,400,400i,600,600i,800,800i);
  @import url(https://cdn.jsdelivr.net/npm/geist@1.3.1/dist/fonts/geist-mono/style.min.css);

  html {
    font-family: "Inter", sans-serif;
    background: #f5f5f4;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-font-smoothing: antialiased;
    color: #1a1a1a;
  }

  code {
    font-family:
      "Geist Mono",
      Menlo,
      Monaco,
      Lucida Console,
      Liberation Mono,
      DejaVu Sans Mono,
      Bitstream Vera Sans Mono,
      Courier New,
      monospace;
  }

  .hover-underline {
    text-decoration: underline 1px rgba(0, 0, 0, 0);
    text-underline-offset: 5px;
    transition: text-decoration-color 300ms;
  }

  .hover-underline:hover {
    text-decoration-color: rgba(0, 0, 0, 0.6);
  }

  .hover-underline-appwrite:hover {
    text-decoration-color: #fd366e !important;
  }

  /* Bracket-notation section label */
  .section-label {
    font-family: "Geist Mono", monospace;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #5cb8a5;
    font-size: 0.875rem;
    font-weight: 500;
  }

  /* Diagonal hatching background */
  .bg-hatching {
    background-image: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 10px,
      rgba(0, 0, 0, 0.02) 10px,
      rgba(0, 0, 0, 0.02) 11px
    );
  }

  .project-article h1,
  .project-article h2,
  .project-article p,
  .project-article ul,
  .project-article hr {
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
  }

  .project-article p:has(img),
  .project-article p:has(.plyr) {
    max-width: 56rem !important;
  }

  .project-article img {
    cursor: pointer;
  }

  .project-article .plyr {
    border: 1px solid #d4d4d4;
    overflow: hidden;
    --plyr-color-main: #1a1a1a;
    --plyr-video-background: #f5f5f4;
    --plyr-video-control-color: #1a1a1a;
    --plyr-video-control-background-hover: rgba(0, 0, 0, 0.05);
    --plyr-video-aspect-ratio: auto;
  }

  .project-article .plyr video {
    margin: 0;
  }

  cap-widget {
    --cap-background: #ffffff;
    --cap-border-color: #d4d4d4;
    --cap-checkbox-background: #f5f5f4;
    --cap-checkbox-border: 1px solid #d4d4d4;
    --cap-color: #1a1a1a;
    --cap-spinner-color: #6b7280;
    --cap-spinner-background-color: #d4d4d4;
    --cap-credits-font-size: 0px;
    --cap-active-scale: 1;
  }
</style>
