---
import { navBarLinks } from "../config";
import type { SEOInfo } from "../types/config";
import { ViewTransitions } from "astro:transitions";

interface Props {
  seo: SEOInfo;
}

const { seo } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(seo.image, Astro.site).toString();

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": "Matej Bačo",
      "alternateName": "Meldiron",
      "url": "https://matejbaco.eu",
    },
    {
      "@type": "Person",
      "name": "Matej Bačo",
      "alternateName": "Meldiron",
      "url": "https://matejbaco.eu",
      "jobTitle": "Engineering Lead",
      "worksFor": {
        "@type": "Organization",
        "name": "Appwrite",
        "url": "https://appwrite.io",
      },
      "image": "https://matejbaco.eu/logo.webp",
      "sameAs": [
        "https://github.com/Meldiron",
        "https://www.linkedin.com/in/matejbaco/",
        "https://discord.com/channels/@me/287294735054274560/",
      ],
    },
    {
      "@type": "SiteNavigationElement",
      "name": "Home",
      "url": "https://matejbaco.eu/",
    },
    {
      "@type": "SiteNavigationElement",
      "name": "Projects",
      "url": "https://matejbaco.eu/projects",
    },
    {
      "@type": "SiteNavigationElement",
      "name": "Blog",
      "url": "https://matejbaco.eu/blog",
    },
    {
      "@type": "SiteNavigationElement",
      "name": "About",
      "url": "https://matejbaco.eu/about",
    },
  ],
};
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/logo.webp" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Matej Bačo" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Matej Bačo" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <ViewTransitions />
    <script is:inline src="https://cdn.jsdelivr.net/npm/appwrite@17.0.0"
    ></script>
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="9cd0e69d-273d-4bbb-88eb-4f10a5019bcd"></script>
  </head>
  <body>
    <header>
      <div
        class="px-6 py-6 max-w-2xl mx-auto flex items-center justify-between"
      >
        <nav>
          <ul>
            {
              navBarLinks.map((link) => (
                <li class="inline pr-3">
                  <a
                    class="opacity-60 hover:opacity-100 hover-underline transition-all"
                    href={link.url}
                    target={link.external ? "_blank" : "_self"}
                  >
                    {link.title}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </header>
    <main class="mb-20 space-y-14">
      <slot />
    </main>
    <footer></footer>

    <script is:inline src="/cap.min.js"></script>
  </body>
</html>

<style is:global>
  @import url(https://fonts.bunny.net/css?family=abhaya-libre:400,500|inter:200,200i,400,400i,600,600i,800,800i);

  html {
    font-family: "Inter", sans-serif;
    background: #121212;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-font-smoothing: antialiased;
    color: #eeeeee;
  }

  code {
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      Liberation Mono,
      DejaVu Sans Mono,
      Bitstream Vera Sans Mono,
      Courier New,
      monospace;
  }

  .hover-underline {
    text-decoration: underline 1px rgba(0, 0, 0, 0);
    text-underline-offset: 5px;
    transition: text-decoration-color 300ms;
  }

  .hover-underline:hover {
    text-decoration-color: rgba(255, 255, 255, 1);
  }

  .hover-underline-appwrite:hover {
    text-decoration-color: #fd366e !important;
  }

  .project-article h1,
  .project-article h2,
  .project-article p,
  .project-article ul,
  .project-article hr {
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
  }

  .project-article p:has(img),
  .project-article p:has(.plyr) {
    max-width: 56rem !important;
  }

  .project-article img {
    cursor: pointer;
  }

  .project-article .plyr {
    border-radius: 1rem;
    border: 2px solid rgb(38 38 38);
    overflow: hidden;
    --plyr-color-main: #eeeeee;
    --plyr-video-background: #121212;
    --plyr-video-control-color: #eeeeee;
    --plyr-video-control-background-hover: rgba(255, 255, 255, 0.1);
    --plyr-video-aspect-ratio: auto;
  }

  .project-article .plyr video {
    margin: 0;
  }

  cap-widget {
    --cap-background: #262626;
    --cap-border-color: #404040;
    --cap-checkbox-background: #171717;
    --cap-checkbox-border: 1px solid #404040;
    --cap-color: white;
    --cap-spinner-color: #d4d4d4;
    --cap-spinner-background-color: #404040;
    --cap-credits-font-size: 0px;
    --cap-active-scale: 1;
  }
</style>
