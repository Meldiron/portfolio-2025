---
import { navBarLinks } from "../config";
import type { SEOInfo } from "../types/config";
import { ViewTransitions } from "astro:transitions";

interface Props {
  seo: SEOInfo;
}

const { seo } = Astro.props;
const siteUrl = Astro.site?.toString() ?? "https://www.matejbaco.eu";
const canonicalURL = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL(seo.image, siteUrl).toString();

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": "Matej Bačo",
      "alternateName": "Meldiron",
      "url": "https://www.matejbaco.eu",
    },
    {
      "@type": "Person",
      "name": "Matej Bačo",
      "alternateName": "Meldiron",
      "url": "https://www.matejbaco.eu",
      "jobTitle": "Engineering Lead",
      "worksFor": {
        "@type": "Organization",
        "name": "Appwrite",
        "url": "https://appwrite.io",
      },
      "image": "https://www.matejbaco.eu/logo.webp",
      "sameAs": [
        "https://github.com/Meldiron",
        "https://www.linkedin.com/in/matejbaco/",
        "https://discord.com/channels/@me/287294735054274560/",
      ],
    },
    {
      "@type": "SiteNavigationElement",
      "name": "Home",
      "url": "https://www.matejbaco.eu/",
    },
    {
      "@type": "SiteNavigationElement",
      "name": "Projects",
      "url": "https://www.matejbaco.eu/projects",
    },
    {
      "@type": "SiteNavigationElement",
      "name": "Blog",
      "url": "https://www.matejbaco.eu/blog",
    },
    {
      "@type": "SiteNavigationElement",
      "name": "About",
      "url": "https://www.matejbaco.eu/about",
    },
  ],
};
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/logo.webp" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Matej Bačo" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Matej Bačo" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <ViewTransitions />
    <script is:inline>
      // Apply saved theme immediately to prevent flash
      (function() {
        const theme = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/appwrite@17.0.0"
    ></script>
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="9cd0e69d-273d-4bbb-88eb-4f10a5019bcd"></script>
  </head>
  <body class="relative overflow-x-hidden">
    <!-- Ambient mesh gradient (split for independent X offset) -->
    <div id="ambient-mesh" class="pointer-events-none fixed inset-0 z-0 overflow-hidden opacity-0">
      <div id="ambient-blue" class="absolute inset-0" style="background: radial-gradient(ellipse 80% 50% at 20% 40%, rgba(59, 130, 246, 0.08), transparent), radial-gradient(ellipse 50% 60% at 30% 80%, rgba(59, 130, 246, 0.04), transparent);"></div>
      <div id="ambient-pink" class="absolute inset-0" style="background: radial-gradient(ellipse 60% 80% at 80% 20%, rgba(236, 72, 153, 0.06), transparent), radial-gradient(ellipse 70% 50% at 75% 70%, rgba(139, 92, 246, 0.05), transparent);"></div>
    </div>

    <!-- Noise texture overlay -->
    <div class="pointer-events-none fixed inset-0 z-[1] opacity-[0.025]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.7%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 256px 256px;"></div>

    <div class="relative z-[2]">
    <header class="fixed top-4 left-0 right-0 z-50 flex justify-center pointer-events-none">
      <div class="pointer-events-auto flex items-center gap-2">
        <nav class="px-1 py-1 rounded-full bg-[var(--glass-bg)] border border-[var(--glass-border)] backdrop-blur-3xl shadow-lg shadow-black/20">
          <ul class="flex items-center gap-0.5">
            {
              navBarLinks.map((link) => (
                <li>
                  <a
                    class="block px-4 py-1.5 text-sm rounded-full text-[var(--text)] opacity-60 hover:opacity-100 hover:bg-[var(--glass-hover)] transition-all"
                    href={link.url}
                    target={link.external ? "_blank" : "_self"}
                  >
                    {link.title}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
        <button
          id="theme-toggle"
          class="w-8 h-8 rounded-full bg-[var(--glass-bg)] border border-[var(--glass-border)] backdrop-blur-3xl shadow-lg shadow-black/20 flex items-center justify-center hover:bg-[var(--glass-hover)] transition-all"
          aria-label="Toggle theme"
        >
          <svg id="icon-sun" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <svg id="icon-moon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>
      </div>
    </header>
    <main class="mb-20 mt-20 space-y-14">
      <slot />
    </main>
    <footer></footer>

    <script is:inline src="/cap.min.js"></script>
    </div>

    <script>
      function initAmbientEffect() {
        const mesh = document.getElementById("ambient-mesh");
        const blue = document.getElementById("ambient-blue");
        const pink = document.getElementById("ambient-pink");
        if (!mesh || !blue || !pink) return;

        // Config: [scrollPosition, opacity, xOffset]
        // xOffset: blue shifts left by this amount, pink shifts right
        const keyframes = [
          [0, 0, 0],
          [700, 1, 0],
          [1000, 1, 200],
          [1500, 1, 0],
          [2000, 1, 300],
          [3000, 1, 0],
          [3200, 1, 0],
          [4200, 0, 0],
        ];

        function interpolate(scrollY: number, valIndex: number): number {
          if (scrollY <= keyframes[0][0]) return keyframes[0][valIndex];
          if (scrollY >= keyframes[keyframes.length - 1][0]) return keyframes[keyframes.length - 1][valIndex];

          for (let i = 0; i < keyframes.length - 1; i++) {
            const startScroll = keyframes[i][0];
            const endScroll = keyframes[i + 1][0];
            if (scrollY >= startScroll && scrollY <= endScroll) {
              const t = (scrollY - startScroll) / (endScroll - startScroll);
              return keyframes[i][valIndex] + t * (keyframes[i + 1][valIndex] - keyframes[i][valIndex]);
            }
          }
          return 0;
        }

        function update() {
          const scrollY = window.scrollY;
          const opacity = interpolate(scrollY, 1);
          const offset = interpolate(scrollY, 2);

          mesh!.style.opacity = String(opacity);
          blue!.style.transform = `translateX(${-offset}px)`;
          pink!.style.transform = `translateX(${offset}px)`;
        }

        window.addEventListener("scroll", update, { passive: true });
        update();
      }

      initAmbientEffect();
      document.addEventListener("astro:page-load", initAmbientEffect);

      function applyTheme(theme: string) {
        document.documentElement.setAttribute("data-theme", theme);
        localStorage.setItem("theme", theme);

        const iconSun = document.getElementById("icon-sun");
        const iconMoon = document.getElementById("icon-moon");
        if (iconSun && iconMoon) {
          if (theme === "light") {
            iconSun.classList.remove("hidden");
            iconMoon.classList.add("hidden");
          } else {
            iconSun.classList.add("hidden");
            iconMoon.classList.remove("hidden");
          }
        }

        const blueEl = document.getElementById("ambient-blue");
        const pinkEl = document.getElementById("ambient-pink");
        if (blueEl && pinkEl) {
          if (theme === "light") {
            blueEl.style.background = "radial-gradient(ellipse 80% 50% at 20% 40%, rgba(59, 130, 246, 0.15), transparent), radial-gradient(ellipse 50% 60% at 30% 80%, rgba(59, 130, 246, 0.08), transparent)";
            pinkEl.style.background = "radial-gradient(ellipse 60% 80% at 80% 20%, rgba(236, 72, 153, 0.12), transparent), radial-gradient(ellipse 70% 50% at 75% 70%, rgba(139, 92, 246, 0.1), transparent)";
          } else {
            blueEl.style.background = "radial-gradient(ellipse 80% 50% at 20% 40%, rgba(59, 130, 246, 0.08), transparent), radial-gradient(ellipse 50% 60% at 30% 80%, rgba(59, 130, 246, 0.04), transparent)";
            pinkEl.style.background = "radial-gradient(ellipse 60% 80% at 80% 20%, rgba(236, 72, 153, 0.06), transparent), radial-gradient(ellipse 70% 50% at 75% 70%, rgba(139, 92, 246, 0.05), transparent)";
          }
        }
      }

      // Use event delegation on document so it works after ViewTransitions DOM swaps
      document.addEventListener("click", (e) => {
        const toggle = (e.target as HTMLElement).closest("#theme-toggle");
        if (!toggle) return;
        const next = document.documentElement.getAttribute("data-theme") === "dark" ? "light" : "dark";
        applyTheme(next);
      });

      // Apply theme on every page load
      function syncTheme() {
        applyTheme(localStorage.getItem("theme") || "dark");
      }
      syncTheme();
      document.addEventListener("astro:page-load", syncTheme);
    </script>
  </body>
</html>

<style is:global>
  @import url(https://fonts.bunny.net/css?family=abhaya-libre:400,500|inter:200,200i,400,400i,600,600i,800,800i);

  /* Dark theme (default) */
  html, html[data-theme="dark"] {
    --bg: #000000;
    --text: #ededed;
    --text-muted: rgba(255, 255, 255, 0.5);
    --glass-bg: rgba(255, 255, 255, 0.03);
    --glass-border: rgba(255, 255, 255, 0.08);
    --glass-hover: rgba(255, 255, 255, 0.1);
    --glass-strong: rgba(255, 255, 255, 0.05);
    --underline-color: rgba(255, 255, 255, 1);
    --underline-hidden: rgba(0, 0, 0, 0);
    --gradient-fade: #000000;
    --prose-body: rgba(255, 255, 255, 0.7);
    --plyr-bg: #000000;
    --plyr-color: #ededed;
    --cap-bg: rgba(255, 255, 255, 0.05);
    --cap-border: rgba(255, 255, 255, 0.1);
    --cap-spinner: rgba(255, 255, 255, 0.5);
    --cap-spinner-bg: rgba(255, 255, 255, 0.1);
    color-scheme: dark;
  }

  /* Light theme */
  html[data-theme="light"] {
    --bg: #f5f5f7;
    --text: #1d1d1f;
    --text-muted: rgba(0, 0, 0, 0.5);
    --glass-bg: rgba(255, 255, 255, 0.08);
    --glass-border: rgba(0, 0, 0, 0.06);
    --glass-hover: rgba(255, 255, 255, 0.30);
    --glass-strong: rgba(255, 255, 255, 0.1);
    --underline-color: rgba(0, 0, 0, 1);
    --underline-hidden: rgba(255, 255, 255, 0);
    --gradient-fade: #f5f5f7;
    --prose-body: rgba(0, 0, 0, 0.7);
    --plyr-bg: #f5f5f7;
    --plyr-color: #1d1d1f;
    --cap-bg: rgba(255, 255, 255, 0.1);
    --cap-border: rgba(0, 0, 0, 0.06);
    --cap-spinner: rgba(0, 0, 0, 0.4);
    --cap-spinner-bg: rgba(0, 0, 0, 0.08);
    --grid-stroke: #000000;
    color-scheme: light;
  }

  html {
    font-family: "Inter", sans-serif;
    background: var(--bg);
    transition: background 0.3s ease;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-font-smoothing: antialiased;
    color: var(--text);
    transition: color 0.3s ease;
  }

  code {
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      Liberation Mono,
      DejaVu Sans Mono,
      Bitstream Vera Sans Mono,
      Courier New,
      monospace;
  }

  .hover-underline {
    text-decoration: underline 1px var(--underline-hidden);
    text-underline-offset: 5px;
    transition: text-decoration-color 300ms;
  }

  .hover-underline:hover {
    text-decoration-color: var(--underline-color);
  }

  .hover-underline-appwrite:hover {
    text-decoration-color: #fd366e !important;
  }

  /* Light theme: invert glass surfaces from white-on-black to dark-on-light */
  html[data-theme="light"] {
    /* Override Tailwind bg-white/[x] to use dark tints instead */
    --tw-bg-opacity: 1;
  }

  /* Glass cards and surfaces in light mode — very low fill, let blur do the work */
  [data-theme="light"] .bg-white\/\[0\.01\],
  [data-theme="light"] .bg-white\/\[0\.02\],
  [data-theme="light"] .bg-white\/\[0\.03\] {
    background-color: rgba(255, 255, 255, 0.08) !important;
  }

  [data-theme="light"] .hover\:bg-white\/\[0\.03\]:hover,
  [data-theme="light"] .hover\:bg-white\/\[0\.05\]:hover {
    background-color: rgba(0, 0, 0, 0.04) !important;
  }

  [data-theme="light"] .bg-white\/5,
  [data-theme="light"] .hover\:bg-white\/5:hover {
    background-color: rgba(255, 255, 255, 0.08) !important;
  }

  [data-theme="light"] .border-white\/\[0\.05\],
  [data-theme="light"] .border-white\/\[0\.06\],
  [data-theme="light"] .border-white\/\[0\.08\] {
    border-color: rgba(0, 0, 0, 0.08) !important;
  }

  [data-theme="light"] .hover\:border-white\/\[0\.1\]:hover,
  [data-theme="light"] .hover\:border-white\/\[0\.15\]:hover {
    border-color: rgba(0, 0, 0, 0.15) !important;
  }

  [data-theme="light"] .border-white\/\[0\.1\] {
    border-color: rgba(0, 0, 0, 0.1) !important;
  }

  [data-theme="light"] .hover\:border-white\/\[0\.2\]:hover {
    border-color: rgba(0, 0, 0, 0.2) !important;
  }

  [data-theme="light"] .hover\:bg-white\/\[0\.05\]:hover {
    background-color: rgba(0, 0, 0, 0.03) !important;
  }

  [data-theme="light"] .bg-white\/\[0\.08\],
  [data-theme="light"] .bg-white\/10 {
    background-color: rgba(0, 0, 0, 0.03) !important;
  }

  [data-theme="light"] .hover\:bg-white\/10:hover {
    background-color: rgba(255, 255, 255, 0.12) !important;
  }

  [data-theme="light"] .text-white\/50,
  [data-theme="light"] .text-white\/40,
  [data-theme="light"] .text-white\/30 {
    color: rgba(0, 0, 0, 0.5) !important;
  }

  [data-theme="light"] .text-white\/60,
  [data-theme="light"] .text-white\/70,
  [data-theme="light"] .text-white\/80 {
    color: rgba(0, 0, 0, 0.7) !important;
  }

  [data-theme="light"] .text-white,
  [data-theme="light"] .text-white\/90,
  [data-theme="light"] .text-\[white\],
  [data-theme="light"] .text-\[\#ffffff\],
  [data-theme="light"] .text-\[\#fff\] {
    color: #1d1d1f !important;
  }

  [data-theme="light"] .opacity-60,
  [data-theme="light"] .opacity-50,
  [data-theme="light"] .opacity-40 {
    opacity: 0.7;
  }

  [data-theme="light"] .ring-white\/\[0\.05\],
  [data-theme="light"] .ring-white\/10,
  [data-theme="light"] .ring-white\/15 {
    --tw-ring-color: rgba(0, 0, 0, 0.08) !important;
  }

  [data-theme="light"] .shadow-white\/\[0\.01\],
  [data-theme="light"] .shadow-white\/\[0\.02\] {
    --tw-shadow-color: rgba(0, 0, 0, 0.03) !important;
  }

  [data-theme="light"] .shadow-black\/20 {
    --tw-shadow-color: rgba(0, 0, 0, 0.08) !important;
  }

  [data-theme="light"] .hover\:bg-white\/10:hover {
    background-color: rgba(0, 0, 0, 0.05) !important;
  }

  /* Contribution graph zero-activity squares */
  [data-theme="light"] .timeline-square[style*="rgba(255, 255, 255, 0.05)"] {
    background-color: rgba(0, 0, 0, 0.05) !important;
  }

  /* Prose overrides for light */
  [data-theme="light"] .prose-invert {
    --tw-prose-body: rgba(0, 0, 0, 0.7);
    --tw-prose-headings: #1d1d1f;
    --tw-prose-links: #2563eb;
    --tw-prose-bold: #1d1d1f;
    --tw-prose-counters: rgba(0, 0, 0, 0.5);
    --tw-prose-bullets: rgba(0, 0, 0, 0.3);
    --tw-prose-hr: rgba(0, 0, 0, 0.1);
    --tw-prose-quotes: #1d1d1f;
    --tw-prose-code: #1d1d1f;
    --tw-prose-pre-code: #1d1d1f;
    --tw-prose-pre-bg: rgba(0, 0, 0, 0.03);
  }

  /* Override prose-p:text-white/70 utility in light mode */
  [data-theme="light"] .prose p {
    color: rgba(0, 0, 0, 0.7) !important;
  }
  [data-theme="light"] .prose li {
    color: rgba(0, 0, 0, 0.7) !important;
  }
  [data-theme="light"] .prose h1,
  [data-theme="light"] .prose h2,
  [data-theme="light"] .prose h3,
  [data-theme="light"] .prose h4 {
    color: #1d1d1f !important;
  }
  [data-theme="light"] .prose a {
    color: #2563eb !important;
  }
  [data-theme="light"] .prose strong {
    color: #1d1d1f !important;
  }
  [data-theme="light"] .prose code {
    color: #1d1d1f !important;
  }
  [data-theme="light"] .prose hr {
    border-color: rgba(0, 0, 0, 0.1) !important;
  }

  /* Community stamps board — light theme */
  [data-theme="light"] .from-neutral-950 { --tw-gradient-from: #f0f0f2 !important; }
  [data-theme="light"] .via-black { --tw-gradient-stops: var(--tw-gradient-from), #e8e8ec var(--tw-gradient-via-position), var(--tw-gradient-to) !important; }
  [data-theme="light"] .to-neutral-950 { --tw-gradient-to: #f0f0f2 !important; }
  [data-theme="light"] .border-neutral-700 { border-color: rgba(0, 0, 0, 0.1) !important; }
  [data-theme="light"] .border-neutral-600 { border-color: rgba(0, 0, 0, 0.12) !important; }
  [data-theme="light"] .border-neutral-500 { border-color: rgba(0, 0, 0, 0.15) !important; }
  [data-theme="light"] .bg-neutral-900\/80 { background-color: rgba(255, 255, 255, 0.8) !important; }
  [data-theme="light"] .bg-neutral-800\/90 { background-color: rgba(255, 255, 255, 0.85) !important; }
  [data-theme="light"] .bg-neutral-950 { background-color: #f0f0f2 !important; }
  [data-theme="light"] .bg-neutral-700\/80 { background-color: rgba(0, 0, 0, 0.06) !important; }
  [data-theme="light"] .bg-neutral-600 { background-color: rgba(0, 0, 0, 0.1) !important; }
  [data-theme="light"] .bg-neutral-400 { background-color: rgba(0, 0, 0, 0.3) !important; }
  [data-theme="light"] .hover\:bg-neutral-600\/80:hover { background-color: rgba(0, 0, 0, 0.08) !important; }
  [data-theme="light"] .hover\:bg-neutral-800:hover { background-color: rgba(0, 0, 0, 0.05) !important; }
  [data-theme="light"] .text-neutral-300 { color: rgba(0, 0, 0, 0.5) !important; }
  [data-theme="light"] .text-neutral-400 { color: rgba(0, 0, 0, 0.4) !important; }
  [data-theme="light"] .border-t-white { border-top-color: #1d1d1f !important; }
  [data-theme="light"] .focus\:bg-neutral-950:focus { background-color: rgba(255, 255, 255, 0.9) !important; }
  [data-theme="light"] .focus\:border-neutral-400:focus { border-color: rgba(0, 0, 0, 0.3) !important; }
  [data-theme="light"] .from-black\/10 { --tw-gradient-from: rgba(0, 0, 0, 0.03) !important; }

  /* Noise overlay lighter in light mode */
  [data-theme="light"] .opacity-\[0\.025\] {
    opacity: 0.015 !important;
  }

  /* Contribution graph colors — dark theme */
  .contrib-0 { background-color: rgba(255, 255, 255, 0.05); }
  .contrib-1 { background-color: #0e4429; }
  .contrib-2 { background-color: #006d32; }
  .contrib-3 { background-color: #26a641; }
  .contrib-4 { background-color: #39d353; }

  /* Contribution graph colors — light theme */
  [data-theme="light"] .contrib-0 { background-color: rgba(0, 0, 0, 0.04); }
  [data-theme="light"] .contrib-1 { background-color: #c2eacc; }
  [data-theme="light"] .contrib-2 { background-color: #85dea0; }
  [data-theme="light"] .contrib-3 { background-color: #57cc7e; }
  [data-theme="light"] .contrib-4 { background-color: #36b95c; }

  /* AI pill icons: only darken white SVGs in light mode */
  [data-theme="light"] .ai-icon-white {
    filter: brightness(0.2);
  }

  /* Hero logo swap */
  [data-theme="light"] .hero-logo-dark {
    display: none !important;
  }
  [data-theme="light"] .hero-logo-light {
    display: block !important;
  }

  .project-article h1,
  .project-article h2,
  .project-article p,
  .project-article ul,
  .project-article hr {
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
  }

  .project-article p:has(img),
  .project-article p:has(.plyr) {
    max-width: 56rem !important;
  }

  .project-article img {
    cursor: pointer;
  }

  .project-article .plyr {
    border-radius: 0.75rem;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    overflow: hidden;
    --plyr-color-main: var(--plyr-color);
